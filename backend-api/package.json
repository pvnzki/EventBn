{
  "name": "eventbn-backend-api",
  "version": "1.0.0",
  "description": "Backend API for EventBn - Event booking application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:safety": "node scripts/check-test-safety.js",
    "test": "npm run test:safety && jest",
    "test:unit": "npm run test:safety && jest tests/unit",
    "test:unit:safe": "jest --config jest.unit.config.js",
    "test:integration": "npm run test:safety && jest tests/integration",
    "test:watch": "npm run test:safety && jest --watch",
    "test:unit:watch": "npm run test:safety && jest tests/unit --watch",
    "test:integration:watch": "npm run test:safety && jest tests/integration --watch",
    "test:coverage": "npm run test:safety && jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "keywords": [
    "nodejs",
    "express",
    "api",
    "event-booking",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
