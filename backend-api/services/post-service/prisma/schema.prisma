generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  post_id          Int       @id @default(autoincrement())
  user_id          Int
  event_id         Int?
  caption          String
  image_url        String?   @db.VarChar(255)
  images           String[]  @default([])      // Array of image URLs
  videos           String[]  @default([])  
  engagement_count Int?      @default(0)
  comment_count    Int?      @default(0)
  allow_comments   Boolean   @default(true)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @updatedAt

  // Relations (with custom fields not in DB)  
  comments        Comment[]
  likes           PostLike[]

  @@map("posts")
}

model Comment {
  comment_id        Int       @id @default(autoincrement())
  post_id          Int
  user_id          Int
  comment_text     String
  parent_comment_id Int?
  like_count       Int       @default(0)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @updatedAt

  // Relations
  post            Post      @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  parent          Comment?  @relation("CommentReplies", fields: [parent_comment_id], references: [comment_id])
  replies         Comment[] @relation("CommentReplies")
  likes           CommentLike[]

  @@map("comments")
}

model PostLike {
  id        Int      @id @default(autoincrement())
  user_id   Int
  post_id   Int
  created_at DateTime? @default(now()) @db.Timestamp(6)

  // Relations
  post      Post     @relation(fields: [post_id], references: [post_id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("post_likes")
}

model CommentLike {
  id         Int      @id @default(autoincrement())
  user_id    Int
  comment_id Int
  created_at DateTime? @default(now()) @db.Timestamp(6)

  // Relations  
  comment   Comment  @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade)

  @@unique([user_id, comment_id])
  @@map("comment_likes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reactions {
  reaction_id   Int       @id @default(autoincrement())
  post_id       Int
  user_id       Int
  reaction_type String    @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model users {
  id         String    @id @db.Uuid
  full_name  String?
  avatar_url String?
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}
