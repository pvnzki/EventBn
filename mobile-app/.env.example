# Environment Configuration for Event Booking App
# Copy this file to .env and fill in your actual values

# API Configuration
BASE_URL=http://10.0.2.2:3001   # Your backend API URL
POST_SERVICE_URL=http://10.0.2.2:3002   # Your post service URL
NOTIFICATION_SERVICE_URL=http://10.0.2.2:3003   # Your notification service URL

# PayHere Configuration
# Get these credentials from your PayHere merchant account
PAYHERE_MERCHANT_ID=your_merchant_id_here
PAYHERE_MERCHANT_SECRET=your_merchant_secret_here
PAYHERE_NOTIFY_URL=https://your-domain.com/payhere/notify
PAYHERE_SANDBOX=true  # Set to false for production

# Stripe Configuration (if using Stripe)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# App Configuration
APP_NAME=Event Booking App
APP_VERSION=1.0.0

# Debug Mode
DEBUG=true